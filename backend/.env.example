# 앱
ENVIRONMENT=development
DEBUG=true

# 데이터베이스
DATABASE_URL=postgresql+asyncpg://dooeyflow:dooeyflow@db:5432/dooeyflow

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (운영 환경에서는 반드시 안전한 난수로 교체)
